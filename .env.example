# =============================================================================
# langgraph-task-orchestrator — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All defaults below work on the FREE tier — no credit card required.
# =============================================================================

# -----------------------------------------------------------------------------
# DEMO MODE
# Set to "true" to force all providers to free-tier alternatives.
# When true: LLM_PROVIDER=groq, VECTOR_STORE=chroma, CHECKPOINT_DB=sqlite
# -----------------------------------------------------------------------------
DEMO_MODE=true

# -----------------------------------------------------------------------------
# LLM PROVIDER
# FREE:       groq     — https://console.groq.com (free, no card)
# PRODUCTION: azure    — Azure OpenAI GPT-4o deployment
# OPTIONS:    groq | azure | openai | anthropic
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Azure OpenAI (production only — leave blank for demo)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# OpenAI direct (optional fallback)
OPENAI_API_KEY=

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# VECTOR STORE
# FREE:       chroma   — Local ChromaDB, zero setup, data in ./chroma_db/
# PRODUCTION: qdrant   — Qdrant Cloud free tier (1GB) or self-hosted
# OPTIONS:    chroma | qdrant
# -----------------------------------------------------------------------------
VECTOR_STORE=chroma

# Qdrant (production or hosted demo — leave blank for local chroma)
QDRANT_URL=
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# CHECKPOINTER (LangGraph state persistence for HITL)
# FREE:       sqlite   — Local SQLite, data in ./checkpoints.sqlite
# PRODUCTION: postgres — Managed PostgreSQL (Supabase free tier or Azure)
# -----------------------------------------------------------------------------
CHECKPOINT_DB_PATH=./checkpoints.sqlite

# Supabase (optional — free tier available at supabase.com)
SUPABASE_URL=
SUPABASE_KEY=

# -----------------------------------------------------------------------------
# OBSERVABILITY — LANGFUSE (LLM tracing)
# FREE: https://cloud.langfuse.com — free tier, no card
# Leave blank to disable tracing (system still works)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# EXPERIMENT TRACKING — DAGSHUB MLFLOW
# FREE: https://dagshub.com — free tier
# Leave blank to disable experiment logging (system still works)
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=
DAGSHUB_TOKEN=

# -----------------------------------------------------------------------------
# SEC EDGAR IDENTITY (required by SEC fair use policy — use your real info)
# No account needed — just provide your name and email
# -----------------------------------------------------------------------------
EDGAR_IDENTITY=Your Name your@email.com