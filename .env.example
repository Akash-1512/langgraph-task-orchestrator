# LLM Provider (groq | openai | azure)
LLM_PROVIDER=groq

# Groq API Key — get free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq Model
GROQ_MODEL=llama-3.3-70b-versatile

# Vector Store Backend (chroma | qdrant)
VECTOR_STORE=chroma

# Qdrant Cloud (only needed if VECTOR_STORE=qdrant)
QDRANT_URL=your_qdrant_cluster_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# Supabase (audit logs)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Langfuse (LLM observability)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# DagsHub MLflow (experiment tracking)
MLFLOW_TRACKING_URI=your_dagshub_mlflow_uri_here
DAGSHUB_TOKEN=your_dagshub_token_here
